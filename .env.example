SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Optional. Without this key the API still works with deterministic answers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/interactions

AGENT_MAX_PRODUCTS=12
CORS_ORIGINS=*

# Text-to-Speech (edge-tts). No API key needed.
TTS_VOICE=uk-UA-PolinaNeural
TTS_RATE=+0%
